# ========================================
# CONFIGURAÇÃO LOCAL (Desenvolvimento)
# ========================================

# FastAPI
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=DEBUG
API_TITLE=E-Cernova Livro Caixa Rural
API_VERSION=0.1.0

# Servidor
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ========================================
# PostgreSQL (Local)
# ========================================
DATABASE_URL=postgresql://cernova:cernova123@localhost:5432/cernova_dev
DB_ECHO=True

# ========================================
# SEFAZ / Captura XML
# ========================================

# MODO: mock (local/testes) ou real (produção)
SEFAZ_MODE=mock
SEFAZ_TIMEOUT=30
SEFAZ_RETRY_MAX=3
SEFAZ_RETRY_BACKOFF=2

# Credenciais SEFAZ (apenas para modo real — NUNCA em código!)
# Depois virão do Key Vault
SEFAZ_USER=
SEFAZ_PASSWORD=
SEFAZ_CERTIFICATE_PATH=

# ========================================
# Claude / IA
# ========================================

# Chave Anthropic (local/dev — depois virá do Key Vault)
ANTHROPIC_API_KEY=sk-ant-

# Modelo e parâmetros
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=2000
CLAUDE_TEMPERATURE=0.3

# ========================================
# Azure (Não necessário localmente, mas configure quando tiver acesso)
# ========================================

# Subscription e Resource Group
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-livcx-dev
AZURE_LOCATION=brazilsouth

# Key Vault
AZURE_KEY_VAULT_NAME=livcx-kv-dev
AZURE_KEY_VAULT_URL=

# Storage Account
AZURE_STORAGE_ACCOUNT_NAME=livcxstoragedev
AZURE_STORAGE_CONTAINER=xml-acervo
AZURE_STORAGE_CONNECTION_STRING=

# PostgreSQL no Azure
AZURE_POSTGRES_SERVER=livcx-pg-dev
AZURE_POSTGRES_DATABASE=junior
AZURE_POSTGRES_USER=

# Managed Identity (será usado em produção)
AZURE_USE_MANAGED_IDENTITY=False
AZURE_CLIENT_ID=
AZURE_TENANT_ID=

# Application Insights
AZURE_APPINSIGHTS_KEY=

# ========================================
# Autenticação (Entra ID / Microsoft)
# ========================================

ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=
ENTRA_REDIRECT_URI=http://localhost:8000/auth/callback

# ========================================
# Logging e Observabilidade
# ========================================

# Serilog / Estruturado
LOG_FORMAT=json  # json ou plain
LOG_OUTPUT=console  # console, file, ou beide

# Arquivo de log (local)
LOG_FILE_PATH=./logs/app.log

# ========================================
# Segurança
# ========================================

# JWT (para autenticação interna)
JWT_SECRET_KEY=seu-secret-aleatorio-super-seguro-nao-use-isso-em-prod
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Login único de admin (sem tabela de usuários ainda — ver docs/07-arquitetura.md)
# ADMIN_PASSWORD_HASH é um hash bcrypt, não a senha em texto puro. Gere com:
#   python -c "from src.api.middleware.auth import hash_password; print(hash_password('sua-senha'))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true

# ========================================
# Rate Limiting
# ========================================

RATE_LIMIT_ENABLED=False  # Desabilitar localmente para facilitar testes
RATE_LIMIT_PER_MINUTE=60

# ========================================
# Testes
# ========================================

# Modo teste (desabilita alguns checks, usa dados mock)
TESTING=False
TEST_DATABASE_URL=sqlite:///./test.db

# ========================================
# Miscellaneous
# ========================================

# Timezone
TIMEZONE=America/Sao_Paulo

# Permitir shutdown via endpoint (APENAS dev/test)
ALLOW_SHUTDOWN=True
